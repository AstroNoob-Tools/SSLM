{
  "name": "sslm-seastar-library-manager",
  "version": "1.0.0-preproduction",
  "description": "SSLM - SeeStar Library Manager: Astrophotography library management application with local web interface",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --output dist/sslm.exe",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "astrophotography",
    "seestar",
    "seastar",
    "library-manager",
    "sslm",
    "astronomy"
  ],
  "author": "AstroNoob Tools",
  "license": "PolyForm-Noncommercial-1.0.0",
  "dependencies": {
    "check-disk-space": "^3.4.0",
    "express": "^4.22.1",
    "fs-extra": "^11.3.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@yao-pkg/pkg": "^6.14.0",
    "nodemon": "^3.1.13",
    "rcedit": "^5.0.2",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  },
  "pkg": {
    "targets": [
      "node20-win-x64"
    ],
    "assets": [
      "public/**/*",
      "config/**/*",
      "installer/sslm.iss",
      "node_modules/socket.io/client-dist/**"
    ],
    "icon": "public/assets/sslm.ico"
  }
}
